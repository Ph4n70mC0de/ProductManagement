@using Microsoft.AspNetCore.Components.Routing
@using System.Globalization
@using System.Text
@implements IDisposable
@inject NavigationManager NavigationManager

<MudBreadcrumbs Items="_items" Class="mb-4" />

@code {
    private List<MudBlazor.BreadcrumbItem> _items = new();

    [Parameter] public string HomeDisplayName { get; set; } = "Home";
    [Parameter] public string[]? ExcludedPaths { get; set; }

    private string[] GetExcludedPaths() => ExcludedPaths ?? new[] { "login", "not-found" };

    private void OnLocationChanged(object sender, LocationChangedEventArgs e) => BuildBreadcrumbs();

    protected override void OnInitialized()
    {
        BuildBreadcrumbs();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void BuildBreadcrumbs()
    {
        var uri = NavigationManager.Uri.Replace(NavigationManager.BaseUri, "/");
        var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);
        
        _items.Clear();
        _items.Add(new(HomeDisplayName, "/"));

        var currentPath = new StringBuilder();
        foreach (var segment in segments)
        {
            if (GetExcludedPaths().Contains(segment, StringComparer.OrdinalIgnoreCase))
                continue;
                
            currentPath.Append('/').Append(segment);
            var words = segment.Split('-', StringSplitOptions.RemoveEmptyEntries);
            var displayName = string.Join(" ", words.Select(w => 
                CultureInfo.CurrentCulture.TextInfo.ToTitleCase(w.ToLowerInvariant())));
            _items.Add(new(displayName, currentPath.ToString()));
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}