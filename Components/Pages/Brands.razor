@page "/brands"
@inject IBrandService BrandService
@inject ISnackbar Snackbar
@using ProductManagement.Features.Data
@using ProductManagement.Features.Data.Model

<PageTitle>Brands</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Brands</MudText>
    
    <MudTable T="Brand" ServerData="LoadServerData" Hover="true" @ref="_table">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Description">@context.Description</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => OpenDeleteDialog(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@if (_loading)
{
    <MudOverlay Visible="_loading" ZIndex="999">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudOverlay>
}

<MudFab Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenCreateDialog" 
        Style="position: fixed; bottom: 16px; right: 16px;" />

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Create Brand</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newBrand.Name" Label="Name" Required="true" />
        <MudTextField @bind-Value="_newBrand.Description" Label="Description" Lines="3" />
        <MudCheckBox @bind-Value="_newBrand.IsActive" Label="Active" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="CreateBrand">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Brand</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editingBrand.Name" Label="Name" Required="true" />
        <MudTextField @bind-Value="_editingBrand.Description" Label="Description" Lines="3" />
        <MudCheckBox @bind-Value="_editingBrand.IsActive" Label="Active" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="UpdateBrand">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Delete Brand</MudText>
    </TitleContent>
    <DialogContent>
        Are you sure you want to delete "@_brandToDelete?.Name"?
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="DeleteBrand">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading;
    private MudTable<Brand> _table = null!;
    
    private bool _createDialogVisible;
    private bool _editDialogVisible;
    private bool _deleteDialogVisible;
    
    private Brand _newBrand = new();
    private Brand _editingBrand = null!;
    private Brand? _brandToDelete;

    private async Task<TableData<Brand>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            var result = await BrandService.GetBrandsPagedAsync(state.Page + 1, state.PageSize);
            return new TableData<Brand> 
            { 
                Items = result.Items, 
                TotalItems = result.TotalCount 
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading brands: {ex.Message}", Severity.Error);
            return new TableData<Brand>();
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenCreateDialog()
    {
        _newBrand = new Brand { CreatedAt = DateTime.UtcNow, IsActive = true };
        _createDialogVisible = true;
    }

    private void CloseCreateDialog()
    {
        _createDialogVisible = false;
    }

    private async Task CreateBrand()
    {
        try
        {
            _loading = true;
            await BrandService.CreateBrandAsync(_newBrand);
            _createDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Brand created successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating brand: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditDialog(Brand brand)
    {
        _editingBrand = brand;
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
    }

    private async Task UpdateBrand()
    {
        try
        {
            _loading = true;
            await BrandService.UpdateBrandAsync(_editingBrand);
            _editDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Brand updated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating brand: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDeleteDialog(Brand brand)
    {
        _brandToDelete = brand;
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _brandToDelete = null;
    }

    private async Task DeleteBrand()
    {
        if (_brandToDelete != null)
        {
            try
            {
                _loading = true;
                await BrandService.DeleteBrandAsync(_brandToDelete.Id);
                _deleteDialogVisible = false;
                await _table.ReloadServerData();
                Snackbar.Add("Brand deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting brand: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }
}