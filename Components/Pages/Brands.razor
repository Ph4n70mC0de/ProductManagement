@page "/brands"
@attribute [Authorize]
@inject IBrandService BrandService
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Web
@using ProductManagement.Features.Data
@using ProductManagement.Features.Data.Model

<PageTitle>Brands</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Brands</MudText>
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="@(_loading ? "" : "mud-invisible")" Style="height: 3px;" aria-label="Loading brands data" />
    
    <MudPaper Class="pa-4 mb-4">
        <MudTextField @bind-Value="_searchString" Placeholder="Search by name or description" 
                      AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start" OnAdornmentClick="OnSearchClick"
                      Immediate="true" IconSize="Size.Medium" Class="mt-0"
                      OnKeyUp="OnSearchKeyUp"></MudTextField>
    </MudPaper>

    <MudTable T="Brand" ServerData="LoadServerData" Hover="true" @ref="_table">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (_loading)
            {
                <MudTd><MudSkeleton Width="70%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="60%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="40%" Height="24px" /></MudTd>
                <MudTd><MudSkeleton Width="80px" Height="36px" /></MudTd>
            }
            else
            {
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => OpenDeleteDialog(context)" />
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Color="Color.Default" Class="pa-4">No brands found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>
<MudFab StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenCreateDialog" 
        Style="position: fixed; bottom: 16px; right: 16px;" />

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Create Brand</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newBrand.Name" Label="Name" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newBrand.Description" Label="Description" Lines="3" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_newBrand.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="CreateBrand">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Brand</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editingBrand.Name" Label="Name" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingBrand.Description" Label="Description" Lines="3" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_editingBrand.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="UpdateBrand">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-2" /> Delete Brand</MudText>
    </TitleContent>
    <DialogContent>
        Are you sure you want to delete "@_brandToDelete?.Name"? This action cannot be undone.
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="DeleteBrand">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading;
    private MudTable<Brand> _table = null!;
    
    private bool _createDialogVisible;
    private bool _editDialogVisible;
    private bool _deleteDialogVisible;
    
    private string _searchString = "";
    private Timer? _searchTimer;

    private Brand _newBrand = new();
    private Brand _editingBrand = null!;
    private Brand? _brandToDelete;

    protected override async Task OnInitializedAsync()
    {
        try
        {
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task<TableData<Brand>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            var result = await BrandService.GetBrandsPagedAsync(state.Page + 1, state.PageSize, _searchString, cancellationToken);
            return new TableData<Brand> 
            { 
                Items = result.Items, 
                TotalItems = result.TotalCount 
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading brands: {ex.Message}", Severity.Error);
            return new TableData<Brand>();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchClick()
    {
        await _table.ReloadServerData();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _searchTimer?.Dispose();
            await _table.ReloadServerData();
        }
        else
        {
            _searchTimer?.Dispose();
            _searchTimer = new Timer(async _ => 
            {
                await InvokeAsync(async () => await _table.ReloadServerData());
            }, null, 300, Timeout.Infinite);
        }
    }

    private void OpenCreateDialog()
    {
        _newBrand = new Brand { CreatedAt = DateTime.UtcNow, IsActive = true };
        _createDialogVisible = true;
    }

    private void CloseCreateDialog()
    {
        _createDialogVisible = false;
    }

    private async Task CreateBrand()
    {
        if (string.IsNullOrWhiteSpace(_newBrand.Name))
        {
            Snackbar.Add("Name is required", Severity.Error);
            return;
        }

        try
        {
            _loading = true;
            await BrandService.CreateBrandAsync(_newBrand);
            _createDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Brand created successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating brand: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditDialog(Brand brand)
    {
        _editingBrand = new Brand 
        { 
            Id = brand.Id,
            Name = brand.Name,
            Description = brand.Description,
            IsActive = brand.IsActive,
            CreatedAt = brand.CreatedAt,
            UpdatedAt = brand.UpdatedAt,
            IsDeleted = brand.IsDeleted
        };
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
    }

    private async Task UpdateBrand()
    {
        if (string.IsNullOrWhiteSpace(_editingBrand.Name))
        {
            Snackbar.Add("Name is required", Severity.Error);
            return;
        }

        try
        {
            _loading = true;
            await BrandService.UpdateBrandAsync(_editingBrand);
            _editDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Brand updated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating brand: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDeleteDialog(Brand brand)
    {
        _brandToDelete = brand;
        _pendingDeleteBrand = brand;
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _brandToDelete = null;
        _pendingDeleteBrand = null;
    }

    private async Task DeleteBrand()
    {
        if (_pendingDeleteBrand != null)
        {
            try
            {
                _loading = true;
                await BrandService.DeleteBrandAsync(_pendingDeleteBrand.Id);
                _deleteDialogVisible = false;
                _brandToDelete = null;
                _pendingDeleteBrand = null;
                await _table.ReloadServerData();
                Snackbar.Add("Brand deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting brand: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }

    public void Dispose()
    {
        _searchTimer?.Dispose();
    }
}