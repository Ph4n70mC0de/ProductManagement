@page "/suppliers"
@attribute [Authorize]
@inject ISupplierService SupplierService
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Web
@using ProductManagement.Features.Data
@using ProductManagement.Features.Data.Model

<PageTitle>Suppliers</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Suppliers</MudText>
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="@(_loading ? "" : "mud-invisible")" Style="height: 3px;" aria-label="Loading suppliers data" />
    
    <MudPaper Class="pa-4 mb-4">
        <MudTextField @bind-Value="_searchString" Placeholder="Search by name, email, contact person" 
                      AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start" adornmentclick="OnSearchClick"
                      Immediate="true" IconSize="Size.Medium" Class="mt-0"
                      OnKeyUp="OnSearchKeyUp"></MudTextField>
    </MudPaper>

    <MudTable T="Supplier" ServerData="LoadServerData" Hover="true" @ref="_table">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Contact Person</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Phone</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (_loading)
            {
                <MudTd><MudSkeleton Width="60%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="50%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="70%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="40%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="30%" Height="24px" /></MudTd>
                <MudTd><MudSkeleton Width="80px" Height="36px" /></MudTd>
            }
            else
            {
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Contact Person">@context.ContactPerson</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Phone">@context.Phone</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => OpenDeleteDialog(context)" />
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Color="Color.Default" Class="pa-4">No suppliers found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

<MudFab StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenCreateDialog" 
        Style="position: fixed; bottom: 16px; right: 16px;" />

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Create Supplier</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newSupplier.Name" Label="Name" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newSupplier.ContactPerson" Label="Contact Person" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newSupplier.Email" Label="Email" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newSupplier.Phone" Label="Phone" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newSupplier.Address" Label="Address" Lines="2" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_newSupplier.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="CreateSupplier">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Supplier</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editingSupplier.Name" Label="Name" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingSupplier.ContactPerson" Label="Contact Person" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingSupplier.Email" Label="Email" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingSupplier.Phone" Label="Phone" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingSupplier.Address" Label="Address" Lines="2" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudCheckBox @bind-Value="_editingSupplier.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="UpdateSupplier">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-2" /> Delete Supplier</MudText>
    </TitleContent>
    <DialogContent>
        Are you sure you want to delete "@_supplierToDelete?.Name"? This action cannot be undone.
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="DeleteSupplier">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IEnumerable<Role> RolesList = new List<Role>();
    private bool _loading;
    
    private string _searchString = "";
    private MudTable<Supplier> _table = null!;
    
    private bool _createDialogVisible;
    private bool _editDialogVisible;
    private bool _deleteDialogVisible;
    
    private Supplier _newSupplier = new();
    private Supplier _editingSupplier = null!;
    private Supplier? _supplierToDelete;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // No reference data needed for suppliers
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task<TableData<Supplier>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            var result = await SupplierService.GetSuppliersPagedAsync(state.Page + 1, state.PageSize, _searchString);
            return new TableData<Supplier> 
            { 
                Items = result.Items, 
                TotalItems = result.TotalCount 
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading suppliers: {ex.Message}", Severity.Error);
            return new TableData<Supplier>();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchClick()
    {
        await _table.ReloadServerData();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await _table.ReloadServerData();
        }
    }

    private void OpenCreateDialog()
    {
        _newSupplier = new Supplier { CreatedAt = DateTime.UtcNow, IsActive = true };
        _createDialogVisible = true;
    }

    private void CloseCreateDialog()
    {
        _createDialogVisible = false;
    }

    private async Task CreateSupplier()
    {
        try
        {
            _loading = true;
            await SupplierService.CreateSupplierAsync(_newSupplier);
            _createDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Supplier created successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating supplier: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditDialog(Supplier supplier)
    {
        _editingSupplier = supplier;
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
    }

    private async Task UpdateSupplier()
    {
        try
        {
            _loading = true;
            await SupplierService.UpdateSupplierAsync(_editingSupplier);
            _editDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("Supplier updated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating supplier: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDeleteDialog(Supplier supplier)
    {
        _supplierToDelete = supplier;
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _supplierToDelete = null;
    }

    private async Task DeleteSupplier()
    {
        if (_supplierToDelete != null)
        {
            try
            {
                _loading = true;
                await SupplierService.DeleteSupplierAsync(_supplierToDelete.Id);
                _deleteDialogVisible = false;
                await _table.ReloadServerData();
                Snackbar.Add("Supplier deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting supplier: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }
}