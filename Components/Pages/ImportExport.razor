@page "/import-export"
@attribute [Authorize]
@inject IProductService ProductService
@inject IBrandService BrandService
@inject ICategoryService CategoryService
@inject ISupplierService SupplierService
@inject IDataExportService ExportService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@using ProductManagement.Features.Data.Model
@using CsvHelper
@using CsvHelper.Configuration
@using System.Globalization

<PageTitle>Import/Export</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Import/Export Data</MudText>
    
    <MudTabs Elevation="2" Rounded="true">
        <MudTabPanel Text="Export">
            <MudText Typo="Typo.h6" GutterBottom="true">Export Data</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    @if (_loading)
                    {
                        <MudSkeleton Width="100%" Height="40px" Class="mb-2" />
                        <MudSkeleton Width="100%" Height="40px" Class="mb-2" />
                        <MudSkeleton Width="100%" Height="40px" Class="mb-2" />
                        <MudSkeleton Width="100%" Height="40px" Class="mb-2" />
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExportProducts" FullWidth="true" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" /> Export Products (CSV)
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExportBrands" FullWidth="true" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" /> Export Brands (CSV)
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExportCategories" FullWidth="true" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" /> Export Categories (CSV)
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExportSuppliers" FullWidth="true" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-2" /> Export Suppliers (CSV)
                        </MudButton>
                    }
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        
        <MudTabPanel Text="Import">
            <MudText Typo="Typo.h6" GutterBottom="true">Import Data</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2">
                Upload a CSV file with columns: Name, SKU, Description, Price, Cost, Quantity, IsActive, BrandName, CategoryName, SupplierName
            </MudText>
            <InputFile OnChange="HandleFileSelected" accept=".csv" />
            @if (!string.IsNullOrEmpty(_importMessage))
            {
                <MudAlert Severity="@_importSeverity" Class="mt-4">@_importMessage</MudAlert>
            }
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private IEnumerable<Product> ProductList = new List<Product>();
    private IEnumerable<Brand> BrandList = new List<Brand>();
    private IEnumerable<Category> CategoryList = new List<Category>();
    private IEnumerable<Supplier> SupplierList = new List<Supplier>();
    private string? _importMessage;
    private Severity _importSeverity = Severity.Info;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadData()
    {
        ProductList = await ProductService.GetAllProductsAsync();
        BrandList = await BrandService.GetAllBrandsAsync();
        CategoryList = await CategoryService.GetAllCategoriesAsync();
        SupplierList = await SupplierService.GetAllSuppliersAsync();
    }

    private async Task ExportProducts()
    {
        try
        {
            _loading = true;
            var csvBytes = ExportService.ExportProductsToCsv(ProductList);
            var fileName = $"products_export_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(csvBytes));
            Snackbar.Add("Products exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting products: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportBrands()
    {
        try
        {
            _loading = true;
            var brands = await BrandService.GetAllBrandsAsync();
            var csvBytes = ExportService.ExportBrandsToCsv(brands);
            var fileName = $"brands_export_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(csvBytes));
            Snackbar.Add("Brands exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting brands: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportCategories()
    {
        try
        {
            _loading = true;
            var categories = await CategoryService.GetAllCategoriesAsync();
            var csvBytes = ExportService.ExportCategoriesToCsv(categories);
            var fileName = $"categories_export_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(csvBytes));
            Snackbar.Add("Categories exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting categories: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportSuppliers()
    {
        try
        {
            _loading = true;
            var suppliers = await SupplierService.GetAllSuppliersAsync();
            var csvBytes = ExportService.ExportSuppliersToCsv(suppliers);
            var fileName = $"suppliers_export_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(csvBytes));
            Snackbar.Add("Suppliers exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting suppliers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            _loading = true;
            var file = e.File;
            
            var config = new CsvConfiguration(CultureInfo.InvariantCulture)
            {
                HeaderValidated = null,
                MissingFieldFound = null,
                TrimOptions = TrimOptions.Trim
            };
            
            using var reader = new StreamReader(file.OpenReadStream(1024 * 1024));
            using var csv = new CsvReader(reader, config);
            
            var records = csv.GetRecords<ProductImportDto>().ToList();
            var importedCount = 0;
            var errors = new List<string>();

            foreach (var record in records)
            {
                try
                {
                    var brand = BrandList.FirstOrDefault(b => 
                        b.Name.Equals(record.BrandName, StringComparison.OrdinalIgnoreCase));
                    var category = CategoryList.FirstOrDefault(c => 
                        c.Name.Equals(record.CategoryName, StringComparison.OrdinalIgnoreCase));
                    var supplier = SupplierList.FirstOrDefault(s => 
                        s.Name.Equals(record.SupplierName, StringComparison.OrdinalIgnoreCase));

                    if (brand == null)
                    {
                        errors.Add($"Row {importedCount + 1}: Brand '{record.BrandName}' not found");
                        continue;
                    }
                    if (category == null)
                    {
                        errors.Add($"Row {importedCount + 1}: Category '{record.CategoryName}' not found");
                        continue;
                    }
                    if (supplier == null)
                    {
                        errors.Add($"Row {importedCount + 1}: Supplier '{record.SupplierName}' not found");
                        continue;
                    }

                    var product = new Product
                    {
                        Name = record.Name,
                        SKU = record.SKU,
                        Description = record.Description ?? string.Empty,
                        Price = record.Price,
                        Cost = record.Cost,
                        Quantity = record.Quantity,
                        BrandId = brand.Id,
                        CategoryId = category.Id,
                        SupplierId = supplier.Id,
                        CreatedAt = DateTime.UtcNow,
                        IsActive = record.IsActive,
                        IsDeleted = false
                    };
                    
                    await ProductService.CreateProductAsync(product);
                    importedCount++;
                }
                catch (Exception ex)
                {
                    errors.Add($"Row {importedCount + 1}: {ex.Message}");
                }
            }

            var message = $"Successfully imported {importedCount} product(s).";
            if (errors.Any())
            {
                message += $" {errors.Count} error(s): {string.Join("; ", errors.Take(3))}";
                if (errors.Count > 3)
                    message += $" (+{errors.Count - 3} more)";
                _importSeverity = errors.Count == records.Count ? Severity.Error : Severity.Warning;
            }
            else
            {
                _importSeverity = Severity.Success;
            }
            
            _importMessage = message;
            await LoadData();
        }
        catch (Exception ex)
        {
            _importMessage = $"Error importing products: {ex.Message}";
            _importSeverity = Severity.Error;
        }
        finally
        {
            _loading = false;
        }
    }

    private class ProductImportDto
    {
        public string Name { get; set; } = string.Empty;
        public string SKU { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal Price { get; set; }
        public decimal Cost { get; set; }
        public int Quantity { get; set; }
        public bool IsActive { get; set; } = true;
        public string BrandName { get; set; } = string.Empty;
        public string CategoryName { get; set; } = string.Empty;
        public string SupplierName { get; set; } = string.Empty;
    }
}