@page "/users"
@attribute [Authorize]
@inject IUserService UserService
@inject IRoleRepository RoleRepository
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Web
@using ProductManagement.Features.Data
@using ProductManagement.Features.Data.Model
@using ProductManagement.Features.Repositories.Interfaces

<PageTitle>Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudOverlay Visible="_loading" ZIndex="999">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudOverlay>
    <MudText Typo="Typo.h4" GutterBottom="true">Users</MudText>
    
    <MudPaper Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
<MudTextField @bind-Value="_searchString" Placeholder="Search by username or email" 
                          AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.Start" OnAdornmentClick="OnSearchClick"
                          Immediate="true" IconSize="Size.Medium" Class="mt-0"
                          OnKeyUp="OnSearchKeyUp"></MudTextField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect @bind-Value="_statusFilter" Label="Filter by Status" Clearable="true" Variant="Variant.Outlined" Immediate="true"
                           @bind-Value:after="OnFilterChangedAsync">
                    <MudSelectItem Value="true">Active</MudSelectItem>
                    <MudSelectItem Value="false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable T="User" ServerData="LoadServerData" Hover="true" @ref="_table">
        <HeaderContent>
            <MudTh>Username</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (_loading)
            {
                <MudTd><MudSkeleton Width="80%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="70%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="60%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="50%" Height="24px" /></MudTd>
                <MudTd><MudSkeleton Width="70%" Height="20px" /></MudTd>
                <MudTd><MudSkeleton Width="80px" Height="36px" /></MudTd>
            }
            else
            {
                <MudTd DataLabel="Username">@context.Username</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Role">@context.Role?.Name</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Created">@context.CreatedAt.ToString("g")</MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => OpenDeleteDialog(context)" />
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Color="Color.Default" Class="pa-4">No users found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

<MudFab StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenCreateDialog" 
        Style="position: fixed; bottom: 16px; right: 16px;" />

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Create User</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newUser.Username" Label="Username" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newUser.Email" Label="Email" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_newUser.PasswordHash" Label="Password" InputType="InputType.Password" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudSelect @bind-Value="_newUser.RoleId" Label="Role" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3">
            @foreach (var role in RolesList)
            {
                <MudSelectItem Value="role.Id">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudCheckBox @bind-Value="_newUser.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="CreateUser">Create</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Edit User</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editingUser.Username" Label="Username" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingUser.Email" Label="Email" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_editingUser.PasswordHash" Label="Password (leave blank to keep current)" InputType="InputType.Password" Variant="Variant.Outlined" Immediate="true" Class="mb-3" />
        <MudSelect @bind-Value="_editingUser.RoleId" Label="Role" Required="true" Variant="Variant.Outlined" Immediate="true" Class="mb-3">
            @foreach (var role in RolesList)
            {
                <MudSelectItem Value="role.Id">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudCheckBox @bind-Value="_editingUser.IsActive" Label="Active" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="UpdateUser">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-2" /> Delete User</MudText>
    </TitleContent>
    <DialogContent>
        Are you sure you want to delete "@_userToDelete?.Username"? This action cannot be undone.
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="DeleteUser">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IEnumerable<Role> RolesList = new List<Role>();
    private bool _loading;
    
    private string _searchString = "";
    private bool? _statusFilter;
    private MudTable<User> _table = null!;
    
    private bool _createDialogVisible;
    private bool _editDialogVisible;
    private bool _deleteDialogVisible;
    
    private User _newUser = new();
    private User _editingUser = null!;
    private User? _userToDelete;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            RolesList = await RoleRepository.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading roles: {ex.Message}", Severity.Error);
        }
    }

    private async Task<TableData<User>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            var result = await UserService.GetUsersPagedAsync(state.Page + 1, state.PageSize, _searchString, _statusFilter);
            return new TableData<User> 
            { 
                Items = result.Items, 
                TotalItems = result.TotalCount 
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading users: {ex.Message}", Severity.Error);
            return new TableData<User>();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchClick()
    {
        await _table.ReloadServerData();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await _table.ReloadServerData();
        }
    }

    private async Task OnFilterChangedAsync()
    {
        await _table.ReloadServerData();
    }

    private void OpenCreateDialog()
    {
        _newUser = new User { CreatedAt = DateTime.UtcNow, IsActive = true, RoleId = 1 };
        _createDialogVisible = true;
    }

    private void CloseCreateDialog()
    {
        _createDialogVisible = false;
    }

    private async Task CreateUser()
    {
        try
        {
            _loading = true;
            await UserService.CreateUserAsync(_newUser);
            _createDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("User created successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating user: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditDialog(User user)
    {
        _editingUser = new User 
        { 
            Id = user.Id, 
            Username = user.Username,
            Email = user.Email,
            RoleId = user.RoleId,
            IsActive = user.IsActive,
            CreatedAt = user.CreatedAt
        };
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
    }

    private async Task UpdateUser()
    {
        try
        {
            _loading = true;
            await UserService.UpdateUserAsync(_editingUser);
            _editDialogVisible = false;
            await _table.ReloadServerData();
            Snackbar.Add("User updated successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating user: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDeleteDialog(User user)
    {
        _userToDelete = user;
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
        _userToDelete = null;
    }

    private async Task DeleteUser()
    {
        if (_userToDelete != null)
        {
            try
            {
                _loading = true;
                await UserService.DeleteUserAsync(_userToDelete.Id);
                _deleteDialogVisible = false;
                await _table.ReloadServerData();
                Snackbar.Add("User deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting user: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
            }
        }
    }
}
