@page "/not-found"

<PageTitle>Not Found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="3" Class="pa-8" Style="text-align: center;">
        <MudIcon Icon="@Icons.Material.Filled.Error" Style="font-size: 64px; color: #f44336;" />
        <MudText Typo="Typo.h4" Class="mt-4">404 - Page Not Found</MudText>
        <MudText Typo="Typo.body1" Class="mt-2">The page you are looking for does not exist.</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Go Home</MudButton>
    </MudPaper>
</MudContainer>